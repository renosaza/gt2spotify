// Safe defaults. Local overrides belong in ignored Config.xcconfig.
// xcconfig treats // as a comment, so build HTTPS URLs from a slash variable.
GT2SPOTIFY_SLASH = /
SPOTIFY_CLIENT_ID =
SPOTIFY_REDIRECT_URI = https:$(GT2SPOTIFY_SLASH)$(GT2SPOTIFY_SLASH)renosaza.github.io/gt2spotify/oauth/callback.html
APP_URL_SCHEME = gt2spotify
#include? "Config.xcconfig"
